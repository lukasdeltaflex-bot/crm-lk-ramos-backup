rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para usuários autenticados em sua própria pasta
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regras para clientes e propostas (protegidas por ownerId)
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }
    match /loanProposals/{proposalId} {
      allow read, write: if request.auth != null;
    }
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ABERTURA TOTAL TEMPORÁRIA PARA DEBUG SE O ERRO PERSISTIR
    // match /{document=**} {
    //   allow read, write: if true;
    // }
  }
}
