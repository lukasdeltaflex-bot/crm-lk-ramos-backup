rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra para perfis de usuário
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para configurações do usuário
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regra para Clientes
    match /customers/{docId} {
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow get, list, update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Regra para Propostas
    match /loanProposals/{docId} {
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow get, list, update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // Regra para Lembretes (Agenda) - Simplificada para permitir listagem com filtro ownerId
    match /reminders/{docId} {
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow get, list, update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Regra para produtos (apenas leitura)
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}