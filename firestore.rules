rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Regras para Perfis de Usuário
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Regras para Clientes (Usa ownerId)
    match /customers/{customerId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow write: if isAuthenticated() && (
        (resource == null && request.resource.data.ownerId == request.auth.uid) ||
        (resource != null && resource.data.ownerId == request.auth.uid)
      );
    }

    // Regras para Propostas (Usa ownerId)
    match /loanProposals/{proposalId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow write: if isAuthenticated() && (
        (resource == null && request.resource.data.ownerId == request.auth.uid) ||
        (resource != null && resource.data.ownerId == request.auth.uid)
      );
    }

    // Regras para Lembretes (Usa userId)
    match /reminders/{reminderId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if isAuthenticated() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // Regras para Configurações do Usuário
    match /userSettings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Bloqueio padrão para qualquer outra coleção
    match /{document=**} {
      allow read, write: if false;
    }
  }
}