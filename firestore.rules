rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Regra universal para documentos que possuem o campo ownerId
    function dataOwner() {
      return signedIn() && (
        (resource == null && request.resource.data.ownerId == request.auth.uid) ||
        (resource != null && resource.data.ownerId == request.auth.uid)
      );
    }

    // Perfil do Usuário e Subcoleção de Lembretes
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /reminders/{reminderId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Clientes, Propostas e Configurações
    match /customers/{customerId} {
      allow read, write: if dataOwner();
    }

    match /loanProposals/{proposalId} {
      allow read, write: if dataOwner();
    }

    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}