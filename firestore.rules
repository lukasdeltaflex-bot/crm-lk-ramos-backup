rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    // Permissão total e direta para o usuário em sua própria pasta e subcoleções
    // Isso resolve definitivamente erros de permissão na Agenda, Perfil e Configurações
    match /users/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Regra para Clientes e Propostas baseada no ownerId para garantir privacidade entre usuários
    function isOwner() {
      return signedIn() && (
        (resource == null && request.resource.data.ownerId == request.auth.uid) ||
        (resource != null && resource.data.ownerId == request.auth.uid)
      );
    }

    match /customers/{customerId} {
      allow read, write: if isOwner();
    }

    match /loanProposals/{proposalId} {
      allow read, write: if isOwner();
    }

    match /userSettings/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}