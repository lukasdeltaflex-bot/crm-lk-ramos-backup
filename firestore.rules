
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only manage their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      // Allow authenticated users to read and write.
      // Client-side queries are responsible for filtering reads.
      // Client-side logic is responsible for ensuring users only write their own data.
      allow read, write: if request.auth != null;
    }

    match /loanProposals/{loanProposalId} {
      // Allow authenticated users to read and write.
      // Client-side queries are responsible for filtering reads.
      // Client-side logic is responsible for ensuring users only write their own data.
      allow read, write: if request.auth != null;
    }

    // User settings can only be managed by the owner.
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Products are read-only for authenticated users.
    match /products/{productId} {
        allow read: if request.auth != null;
        allow write: if false;
    }
  }
}
