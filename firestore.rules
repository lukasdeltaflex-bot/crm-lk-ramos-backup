rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    // Função de propriedade robusta que evita erros em campos ausentes
    function isOwner(data) {
      return signedIn() && (
        data.get('userId', '') == request.auth.uid || 
        data.get('ownerId', '') == request.auth.uid ||
        data.get('uid', '') == request.auth.uid
      );
    }

    // Regras para Clientes
    match /customers/{customerId} {
      allow read, write: if isOwner(resource == null ? request.resource.data : resource.data);
    }

    // Regras para Propostas
    match /loanProposals/{proposalId} {
      allow read, write: if isOwner(resource == null ? request.resource.data : resource.data);
    }

    // Regras para Lembretes (Agenda)
    match /reminders/{reminderId} {
      allow read, write: if isOwner(resource == null ? request.resource.data : resource.data);
    }

    // Perfil de Usuário e Configurações
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /userSettings/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    
    // Bloqueio padrão para segurança de outras coleções
    match /{document=**} {
      allow read, write: if false;
    }
  }
}