
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only manage their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      // Allow user to LIST documents. Client query must filter.
      allow list: if request.auth != null;
      // Allow user to GET, UPDATE, DELETE their own documents.
      allow get, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow user to CREATE documents for themselves.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /loanProposals/{loanProposalId} {
      // Allow user to LIST documents. Client query must filter.
      allow list: if request.auth != null;
      // Allow user to GET, UPDATE, DELETE their own documents.
      allow get, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      // Allow user to CREATE documents for themselves.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // User settings can only be managed by the owner.
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Products are read-only for authenticated users.
    match /products/{productId} {
        allow read: if request.auth != null;
        allow write: if false;
    }
  }
}
