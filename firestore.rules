
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // LIBERA QUALQUER LEITURA PARA USUÁRIO LOGADO
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}
