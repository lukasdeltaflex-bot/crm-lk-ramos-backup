
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    // Função para verificar se o usuário é dono do documento (Lida com merge:true)
    function isOwner(data) {
      return signedIn() && data.userId == request.auth.uid;
    }
    
    // Função para dono via ownerId (Clientes/Propostas)
    function isDataOwner(data) {
      return signedIn() && data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      allow read, write: if signedIn() && (
        (resource == null || isDataOwner(resource.data)) &&
        (request.resource == null || isDataOwner(request.resource.data))
      );
    }

    match /loanProposals/{proposalId} {
      allow read, write: if signedIn() && (
        (resource == null || isDataOwner(resource.data)) &&
        (request.resource == null || isDataOwner(request.resource.data))
      );
    }

    // Regra robusta para Lembretes (Agenda)
    match /reminders/{reminderId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /userSettings/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
