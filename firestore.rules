
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é dono do dado (Clientes/Propostas)
    function isDataOwner(data) {
      return signedIn() && data.ownerId == request.auth.uid;
    }
    
    // Verifica se o usuário é dono do lembrete (Agenda)
    function isReminderOwner(data) {
      return signedIn() && data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      allow read, write: if signedIn() && (
        (resource == null || isDataOwner(resource.data)) &&
        (request.resource == null || isDataOwner(request.resource.data))
      );
    }

    match /loanProposals/{proposalId} {
      allow read, write: if signedIn() && (
        (resource == null || isDataOwner(resource.data)) &&
        (request.resource == null || isDataOwner(request.resource.data))
      );
    }

    // Regras simplificadas para Lembretes para evitar erros de permissão em massa
    match /reminders/{reminderId} {
      allow read: if signedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if signedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    match /userSettings/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
