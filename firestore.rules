
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    // Regra universal de propriedade: o usuário logado deve ser o dono do dado
    function isOwner(data) {
      return signedIn() && (
        (data.userId == request.auth.uid) || 
        (data.ownerId == request.auth.uid) ||
        (data.uid == request.auth.uid)
      );
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      allow read, write: if signedIn() && (
        (resource == null || isOwner(resource.data)) &&
        (request.resource == null || isOwner(request.resource.data))
      );
    }

    match /loanProposals/{proposalId} {
      allow read, write: if signedIn() && (
        (resource == null || isOwner(resource.data)) &&
        (request.resource == null || isOwner(request.resource.data))
      );
    }

    match /reminders/{reminderId} {
      allow read, write: if signedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    match /userSettings/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
