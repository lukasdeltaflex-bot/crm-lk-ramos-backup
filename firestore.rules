
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only manage their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      // Users can read a customer document if they are the owner of the record.
      // This rule is secure for queries because the client-side code MUST
      // include a `where('userId', '==', request.auth.uid)` clause.
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Users can create, update, or delete a customer document if they are the owner.
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /loanProposals/{loanProposalId} {
      // Users can read a loan proposal document if they are the owner.
      // This rule is secure for queries because the client-side code MUST
      // include a `where('userId', '==', request.auth.uid)` clause.
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Users can create, update, or delete proposals they own.
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // User settings can only be managed by the owner.
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Products are read-only for authenticated users.
    match /products/{productId} {
        allow read: if request.auth != null;
        allow write: if false;
    }
  }
}
