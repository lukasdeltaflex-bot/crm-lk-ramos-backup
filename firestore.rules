rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper central para autenticação
    function isAuthenticated() {
      return request.auth != null;
    }

    // Perfil de usuário: apenas o próprio dono
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Configurações: apenas o próprio dono
    match /userSettings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Clientes: usa o campo 'ownerId' conforme definido no backend.json
    match /customers/{docId} {
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Propostas: usa o campo 'ownerId' conforme definido no backend.json
    match /loanProposals/{docId} {
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
    
    // Lembretes (Agenda): CORREÇÃO CRÍTICA
    // Usa exclusivamente 'userId' para permitir que o otimizador de queries do Firestore
    // valide o filtro where('userId', '==', auth.uid) sem ambiguidades.
    match /reminders/{docId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Produtos: leitura pública para autenticados
    match /products/{productId} {
      allow read: if isAuthenticated();
    }
  }
}