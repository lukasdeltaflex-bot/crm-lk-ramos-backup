rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    // Regras simplificadas e robustas para garantir acesso total ao dono do dado
    match /customers/{customerId} {
      allow read, write: if signedIn() && (
        (resource == null ? request.resource.data.ownerId : resource.data.ownerId) == request.auth.uid
      );
    }

    match /loanProposals/{proposalId} {
      allow read, write: if signedIn() && (
        (resource == null ? request.resource.data.ownerId : resource.data.ownerId) == request.auth.uid
      );
    }

    match /reminders/{reminderId} {
      allow read, write: if signedIn() && (
        (resource == null ? request.resource.data.userId : resource.data.userId) == request.auth.uid
      );
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /userSettings/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}