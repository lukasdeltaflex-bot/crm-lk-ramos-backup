
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only manage their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      // Allow listing for any authenticated user.
      // The client-side query is responsible for filtering to the user's own documents.
      allow list: if request.auth != null;

      // Allow reading, updating, and deleting a specific document if the user is the owner.
      allow get, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Allow creating a document if the incoming data has the correct owner ID.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /loanProposals/{loanProposalId} {
      allow list: if request.auth != null;
      allow get, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // User settings can only be managed by the owner.
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Products are read-only for authenticated users.
    match /products/{productId} {
        allow read: if request.auth != null;
        allow write: if false;
    }
  }
}
