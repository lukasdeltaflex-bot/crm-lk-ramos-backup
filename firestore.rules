rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Regras para Perfis de Usuário
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Regras para Clientes (usam ownerId)
    match /customers/{customerId} {
      allow read: if isAuthenticated() && resource.data.get('ownerId', '') == request.auth.uid;
      allow write: if isAuthenticated() && (
        (resource == null && request.resource.data.get('ownerId', '') == request.auth.uid) ||
        (resource != null && resource.data.get('ownerId', '') == request.auth.uid)
      );
    }

    // Regras para Propostas (usam ownerId)
    match /loanProposals/{proposalId} {
      allow read: if isAuthenticated() && resource.data.get('ownerId', '') == request.auth.uid;
      allow write: if isAuthenticated() && (
        (resource == null && request.resource.data.get('ownerId', '') == request.auth.uid) ||
        (resource != null && resource.data.get('ownerId', '') == request.auth.uid)
      );
    }

    // Regras para Lembretes (usam userId)
    match /reminders/{reminderId} {
      allow read: if isAuthenticated() && resource.data.get('userId', '') == request.auth.uid;
      allow write: if isAuthenticated() && (
        (resource == null && request.resource.data.get('userId', '') == request.auth.uid) ||
        (resource != null && resource.data.get('userId', '') == request.auth.uid)
      );
    }

    // Regras para Configurações do Usuário
    match /userSettings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Bloqueio padrão para qualquer outro acesso
    match /{document=**} {
      allow read, write: if false;
    }
  }
}