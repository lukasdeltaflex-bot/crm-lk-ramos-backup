rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function signedIn() {
      return request.auth != null;
    }

    // AGENDA LK - ACESSO TOTAL (Liberado para evitar erros de permissão)
    match /users/{userId}/reminders/{reminderId} {
      allow read, write: if true;
    }

    // Perfil e Configurações: Acesso apenas ao próprio UID
    match /users/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Clientes e Propostas: Acesso baseado no ownerId
    function isOwner() {
      return signedIn() && (
        (resource == null && request.resource.data.ownerId == request.auth.uid) ||
        (resource != null && resource.data.ownerId == request.auth.uid)
      );
    }

    match /customers/{customerId} {
      allow read, write: if isOwner();
    }

    match /loanProposals/{proposalId} {
      allow read, write: if isOwner();
    }

    match /userSettings/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}