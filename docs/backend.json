
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Stores user profile information.",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["uid", "email"]
    },
    "UserSettings": {
      "title": "User Settings",
      "type": "object",
      "description": "Global user configurations and persistent states.",
      "properties": {
        "monthlyGoal": { "type": "number" },
        "dismissedAlerts": { "type": "array", "items": { "type": "string" } },
        "productTypes": { "type": "array", "items": { "type": "string" } },
        "proposalStatuses": { "type": "array", "items": { "type": "string" } },
        "banks": { "type": "array", "items": { "type": "string" } },
        "customLogoURL": { "type": "string" },
        "statusColors": { "type": "object" },
        "bankDomains": { "type": "object" },
        "showBankLogos": { "type": "boolean" },
        "radius": { "type": "string" },
        "containerStyle": { "type": "string" },
        "animationStyle": { "type": "string" },
        "fontStyle": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "numericId": { "type": "number" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "gender": { "type": "string", "enum": ["Masculino", "Feminino"] },
        "phone": { "type": "string" },
        "phone2": { "type": "string" },
        "email": { "type": "string" },
        "birthDate": { "type": "string" },
        "ownerId": { "type": "string" },
        "benefits": { "type": "array" },
        "documents": { "type": "array" }
      },
      "required": ["numericId", "name", "cpf", "phone", "ownerId"]
    },
    "LoanProposal": {
      "title": "LoanProposal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "customerId": { "type": "string" },
        "proposalNumber": { "type": "string" },
        "status": { "type": "string" },
        "product": { "type": "string" },
        "bank": { "type": "string" },
        "grossAmount": { "type": "number" },
        "netAmount": { "type": "number" },
        "commissionValue": { "type": "number" },
        "commissionStatus": { "type": "string" },
        "dateDigitized": { "type": "string" },
        "statusAwaitingBalanceAt": { "type": "string", "description": "Momento em que entrou em Aguardando Saldo." },
        "observations": { "type": "string" },
        "history": { 
            "type": "array", 
            "items": { 
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "date": { "type": "string", "format": "date-time" },
                    "message": { "type": "string" },
                    "userName": { "type": "string" }
                }
            }
        }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/users/{userId}/followUps/{followUpId}", "definition": { "entityName": "FollowUp" } },
      { "path": "/users/{userId}/expenses/{expenseId}", "definition": { "entityName": "Expense" } },
      { "path": "/customers/{customerId}", "definition": { "entityName": "Customer" } },
      { "path": "/loanProposals/{loanProposalId}", "definition": { "entityName": "LoanProposal" } },
      { "path": "/userSettings/{userId}", "definition": { "entityName": "UserSettings" } }
    ]
  }
}
